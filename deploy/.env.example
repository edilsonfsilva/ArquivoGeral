# ============================================================
# TJPE Archive Assist — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA versione o arquivo .env com senhas reais.
# ============================================================

# ── Aplicação ──────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# Segredo da sessão HTTP (mínimo 32 caracteres aleatórios)
# Gere com: openssl rand -hex 32
SESSION_SECRET=SUBSTITUA_POR_VALOR_ALEATORIO_FORTE

# ── Banco de Dados PostgreSQL ──────────────────────────────
DATABASE_URL=postgresql://USUARIO:SENHA@HOST:5432/tjpe_archive

# Valores individuais (usados somente pelo serviço db no docker-compose)
POSTGRES_DB=tjpe_archive
POSTGRES_USER=SUBSTITUA_POR_USUARIO
POSTGRES_PASSWORD=SUBSTITUA_POR_SENHA_FORTE

# ── Usuário Administrador Padrão ──────────────────────────
# Criado automaticamente na primeira inicialização se não existir.
# Altere estes valores antes do primeiro deploy.
ADMIN_EMAIL=admin@tjpe.jus.br
ADMIN_NAME=Administrador
ADMIN_PASSWORD=SUBSTITUA_POR_SENHA_FORTE
